{
    "srcDir": "src",
    "localesDir": "src/i18n/locales",
    "sourceLanguage": "en",
    "targetLanguages": ["zh"],
    "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
    "ignorePatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/*.test.*",
      "**/*.spec.*",
      "src/main.tsx",
      "src/routes.tsx",
      "src/layouts/RootLayout.tsx",
      "src/pages/Home.tsx",
      "src/vite-env.d.ts",
      "src/types/**",
      "src/utils/**",
      "src/pages/BLOG/content/**",
      "src/pages/BLOG/styles/**",
      "src/pages/BLOG/utils/**",
      "src/pages/BLOG/**/*.json",
      "src/pages/NEWS/content/**",
      "src/pages/NEWS/styles/**",
      "src/pages/NEWS/utils/**",
      "src/pages/NEWS/**/*.json",
      "src/components/DemoComponent.tsx",
      "src/**/*.stories.*",
      "src/components/LanguageSwitcher.tsx",
      "src/components/LegacyRedirect.tsx",
      "src/components/SeoHead.tsx",
      "src/i18n/**",
      "src/seo/**"
    ],
    "ignoreDirs": [
      "node_modules",
      "dist",
      "build",
      ".git",
      "src/i18n",
      "src/utils"
    ]
  }