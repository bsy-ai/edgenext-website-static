{
    "srcDir": "src",
    "localesDir": "src/i18n/locales",
    "sourceLanguage": "en",
    "targetLanguages": ["zh"],
    "fileExtensions": [".tsx", ".ts", ".jsx", ".js"],
    "ignorePatterns": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/*.test.*",
      "**/*.spec.*",
      "src/App.tsx",
      "src/main.tsx",
      "src/vite-env.d.ts",
      "src/pages/BLOG/**",
      "src/pages/NEWS/**",
      "src/components/DemoComponent.tsx",
      "src/**/*.stories.*",
      "src/components/LanguageSwitcher.tsx",
      "src/i18n/**"
    ],
    "ignoreDirs": [
      "node_modules",
      "dist",
      "build",
      ".git",
      "src/i18n",
      "src/pages/BLOG",
      "src/pages/NEWS",
      "src/i18n/scripts",
      "src/i18n"
    ]
  }